# ============================================================
# TELEGRAM (MTProto User Client)
# Obter em: https://my.telegram.org/apps
# ============================================================
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=          # Ex: +5511999999999
TELEGRAM_SESSION=        # Preenchido automaticamente após login

# ID ou @username do canal a monitorar
# Para descobrir o ID: encaminhe uma mensagem para @userinfobot
TELEGRAM_CHANNEL_ID=     # Ex: -1001234567890 ou @canaldesinais

# ============================================================
# SOLANA
# ============================================================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Para melhor performance use: https://rpc.helius.xyz/?api-key=SEU_KEY
WALLET_PRIVATE_KEY=      # Base58 encoded private key da sua wallet

# ============================================================
# TRADING
# ============================================================
# Modo paper trading (true = simulação, false = real)
PAPER_TRADING=true

# % do saldo da carteira por trade (Ex: 0.05 = 5%)
POSITION_SIZE_PCT=0.05

# Slippage máximo tolerado em bps (100 = 1%)
MAX_SLIPPAGE_BPS=100

# Alavancagem máxima permitida pelo bot (segurança)
MAX_LEVERAGE=20

# Delay antes de executar (ms, 0 = imediato)
EXECUTION_DELAY_MS=0

# Número de retentativas em falha
MAX_RETRIES=3

# Número máximo de posições simultâneas (0 = sem limite)
MAX_POSITIONS=5

# % mínima do free collateral a manter como buffer de segurança (ex: 0.10 = 10%)
MIN_FREE_MARGIN_PCT=0.10

# Exposição nocional total máxima como % do equity (ex: 0.80 = 80%)
MAX_TOTAL_EXPOSURE_PCT=0.80

# Intervalo de atualização do PnL nos cards de posição (ms)
PNL_REFRESH_INTERVAL_MS=30000

# ============================================================
# MONITOR CLI (opcional)
# ============================================================
# Intervalo de atualização do dashboard em ms (padrão: 10000)
MONITOR_REFRESH_MS=10000

# ============================================================
# MONITOR WEB (opcional)
# ============================================================
# Ativar dashboard web (true/false)
ENABLE_WEB=false

# Porta do servidor web (padrão: 3000)
WEB_PORT=3000

# ============================================================
# BOT DE CONTROLE TELEGRAM (opcional)
# ============================================================
# Ativar bot de controle (true/false)
ENABLE_CONTROL_BOT=false

# Token do bot obtido via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=

# IDs dos usuários autorizados a usar o bot de controle
# Para descobrir seu ID: envie qualquer mensagem para @userinfobot
# Separe múltiplos IDs com vírgula: 123456789,987654321
TELEGRAM_CONTROL_ALLOWED_IDS=

# ============================================================
# LOGS
# ============================================================
LOG_LEVEL=info    # debug | info | warn | error
LOG_DIR=./logs
